{
  "name": "AdamAndEshaalsFarm",
  "tree": {
    "$className": "DataModel",

    "Players": {
      "$className": "Players",
      "$properties": {
        "CharacterAutoLoads": false
      }
    },

    "Workspace": {
      "$className": "Workspace",
      "$properties": {
        "FilteringEnabled": true
      }
    },

    "Lighting": {
      "$className": "Lighting",
      "$properties": {
        "Brightness": 2,
        "ClockTime": 10,
        "GlobalShadows": true
      }
    },

    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "GameModules": {
        "$className": "Folder",
        "GameData": {
          "$path": "src/ReplicatedStorage/GameData.lua"
        },
        "CropData": {
          "$path": "src/ReplicatedStorage/CropData.lua"
        },
        "AnimalData": {
          "$path": "src/ReplicatedStorage/AnimalData.lua"
        },
        "GameConfig": {
          "$path": "src/ReplicatedStorage/GameConfig.lua"
        },
        "Remotes": {
          "$path": "src/ReplicatedStorage/Remotes.lua"
        }
      }
    },

    "ServerScriptService": {
      "$className": "ServerScriptService",
      "Main": {
        "$path": "src/ServerScriptService/Main.server.lua"
      },
      "AnimalManager": {
        "$path": "src/ServerScriptService/AnimalManager.server.lua"
      },
      "DataManager": {
        "$path": "src/ServerScriptService/DataManager.server.lua"
      },
      "FarmManager": {
        "$path": "src/ServerScriptService/FarmManager.server.lua"
      },
      "ShopManager": {
        "$path": "src/ServerScriptService/ShopManager.server.lua"
      },
      "GameManager": {
        "$path": "src/ServerScriptService/GameManager.server.lua"
      }
    },

    "StarterPlayer": {
      "$className": "StarterPlayer",
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "ClientController": {
          "$path": "src/StarterPlayer/StarterPlayerScripts/ClientController.client.lua"
        },
        "FarmUI": {
          "$path": "src/StarterPlayer/StarterPlayerScripts/FarmUI.client.lua"
        }
      }
    },

    "StarterGui": {
      "$className": "StarterGui",
      "$properties": {
        "ResetPlayerGuiOnSpawn": false
      }
    }
  }
}
